{
  "name": "mika",
  "module": "index.ts",
  "type": "module",
  "devDependencies": {
    "@types/bun": "latest",
    "concurrently": "^9.1.0",
    "pino-pretty": "^13.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@discordjs/voice": "^0.18.0",
    "discord.js": "^14.16.3",
    "pino": "^9.6.0",
    "shoukaku": "^4.1.1"
  },
  "scripts": {
    "start": "bun run index.ts",
    "lava": "java -jar lavalink/Lavalink.jar",
    "lava:get": "bun run scripts/getLavalink.js",
    "dev": "NODE_ENV=development bun run index.ts --watch | pino-pretty",
    "dev:conc": "NODE_ENV=development concurrently \"bun dev\" \"bun lava\"",
    "build": "bun build ./index.ts --outdir ./dist --target bun --minify",
    "serve": "NODE_ENV=production bun run ./dist/index | pino-pretty",
    "serve:conc": "NODE_ENV=production concurrently \"bun serve\" \"bun lava\""
  }
}
